link-shrink.duckdns.org {
    # Route Grafana to the sub-path
    handle /grafana* {
        reverse_proxy grafana:3000
    }
    
    # Route Prometheus
    handle /prometheus* {
        reverse_proxy prometheus:9090
    }
    
    # Route Alertmanager
    handle /alertmanager* {
        reverse_proxy alertmanager:9093
    }
    
    # Route all other traffic to the main app
    handle {
        reverse_proxy app:5000
    }
}
